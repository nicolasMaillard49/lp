# ── Supabase (écriture serveur-only des leads) ──
# Projet Supabase → Settings → API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# ── Dashboard /admin ──
# Mot de passe unique d'accès au dashboard analytics
ADMIN_PASSWORD=change-moi
# Secret pour signer le cookie de session admin (chaîne aléatoire longue)
ADMIN_COOKIE_SECRET=change-moi-aussi-32-caracteres-mini
